# ============ GitHub ============
GITHUB_TOKEN=xxx_github_token_here
# Несколько токенов через запятую (опционально)
GITHUB_EXTRA_TOKENS=

# ============ Telegram ============
TELEGRAM_BOT_TOKEN=xxx_telegram_bot_token

# ============ LLM (пока не используется, см. README → Роадмап) ============
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
LLM_MODEL=gpt-4o-mini

# ============ Storage ============
DATABASE_URL=sqlite+aiosqlite:///data/app.db
REDIS_URL=redis://localhost:6379/0

# ============ Limits ============
MAX_WORKERS=10
MAX_REQUESTS_PER_USER=10
USER_COOLDOWN_MINUTES=30

# Глубина полного бэкфилла при первой синхронизации репозитория (дней).
# Не путать с периодом в /analyze — это про то, сколько истории вообще
# хранится в БД, а не про то, что показывается в конкретном отчёте.
MAX_BACKFILL_DAYS=730

# ============ Cache TTL (секунды) ============
CACHE_TTL_GITHUB=3600
CACHE_TTL_LLM=86400

# ============ Вебхуки (опционально, см. README → "Вебхуки") ============
# По умолчанию выключено — бот работает через poll-diff, этого достаточно
# для мгновенных повторных отчётов без вебхуков вообще.
# Включай, только если у GITHUB_TOKEN есть admin:repo_hook на репозитории
# ниже (то есть обычно — это ТВОИ собственные репозитории).
WEBHOOK_ENABLED=false
WEBHOOK_SECRET=
# Публичный HTTPS URL перед сервисом webhook (reverse-proxy), например:
# https://example.com/webhook/github
WEBHOOK_PUBLIC_URL=
WEBHOOK_PORT=8080
# Чьи репозитории регистрирует src/webhook/register.py по умолчанию.
OWNER_GITHUB_USERNAME=

# ============ Logging ============
LOG_LEVEL=INFO